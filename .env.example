# Copy to .env — none of these are required to start the app.
# You can paste AI provider keys directly into the UI's Settings panel instead.

# Postgres for chat history / sessions (optional — in-memory if unset)
DATABASE_URL=postgresql://user:password@localhost:5432/codeably

# ── Google OAuth (required for login) ─────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Desktop app type)
# 3. Add authorised redirect URI: http://127.0.0.1:8765/auth/google/callback
# 4. Paste the values below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI provider keys (optional — can also be entered in the UI) ───────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
