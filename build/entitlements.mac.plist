<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's JIT compiler under Hardened Runtime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory (needed by some Electron internals) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Allow DYLD environment variables (used by Electron's node integration) -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- Disable library validation so bundled .dylibs and the PyInstaller binary load -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Network access — needed to call AI provider APIs -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- File access — agent needs to read/write project files -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Allow spawning child processes (the codeably-api binary) -->
  <key>com.apple.security.cs.disable-executable-page-protection</key>
  <true/>
</dict>
</plist>
